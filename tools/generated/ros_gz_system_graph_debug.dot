digraph RosGzSystemGraph {
  graph [rankdir=LR, bgcolor="white", pad="0.2", nodesep="0.45", ranksep="0.85", splines="ortho", label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0"><TR><TD><FONT POINT-SIZE="18"><B>LIDAR Mapping Drone Runtime Graph</B></FONT></TD></TR><TR><TD><FONT POINT-SIZE="14">Gazebo + ROS 2 Debug View</FONT></TD></TR><TR><TD><TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#ffd166"><FONT POINT-SIZE="10">GZ topic</FONT></TD><TD BGCOLOR="#d0b3ff"><FONT POINT-SIZE="10">Bridge</FONT></TD><TD BGCOLOR="#b7e4c7"><FONT POINT-SIZE="10">ROS topic</FONT></TD><TD BGCOLOR="#90caf9"><FONT POINT-SIZE="10">ROS node</FONT></TD><TD BGCOLOR="#ffccd5"><FONT POINT-SIZE="10">Service</FONT></TD></TR></TABLE></TD></TR></TABLE>>, labelloc="t", labeljust="c", fontsize="18", fontname="DejaVu Sans"];
  node [fontname="DejaVu Sans", fontsize="10", style="filled"];
  edge [fontname="DejaVu Sans", fontsize="9", color="#555555", arrowsize="0.8"];

